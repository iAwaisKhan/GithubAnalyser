# Optional: Add a GitHub Personal Access Token to increase rate limits
# Create one at: https://github.com/settings/tokens
# Permissions needed: public_repo (read-only is fine)
GITHUB_TOKEN=your_github_pat_here

# Anthropic API key for AI-powered repo reviews
# Get one at: https://console.anthropic.com/
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# PostgreSQL connection string (Neon, Supabase, or any pg-compatible DB)
# Neon:    postgres://user:password@ep-xxx.us-east-1.aws.neon.tech/neondb?sslmode=require
# Supabase: postgres://postgres:[password]@db.[project].supabase.co:5432/postgres
# Leave unset to disable growth tracking (all other features still work)
DATABASE_URL=postgresql://user:password@host:5432/dbname?sslmode=require

# ── Authentication (NextAuth) ──────────────────────────────────────────────────
# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET=your_nextauth_secret_here
NEXTAUTH_URL=http://localhost:3000

# GitHub OAuth App (github.com/settings/developers → New OAuth App)
# Callback URL: http://localhost:3000/api/auth/callback/github
GITHUB_CLIENT_ID=your_github_oauth_client_id
GITHUB_CLIENT_SECRET=your_github_oauth_client_secret

# Google OAuth (console.cloud.google.com → Credentials → OAuth 2.0)
# Callback URL: http://localhost:3000/api/auth/callback/google
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret

# ── Rate Limiting + Caching (Upstash Redis) ───────────────────────────────────
# Free tier at upstash.com → Create Redis DB → REST API
UPSTASH_REDIS_REST_URL=https://xxx.upstash.io
UPSTASH_REDIS_REST_TOKEN=your_upstash_token

# ── Billing (Stripe) ──────────────────────────────────────────────────────────
# dashboard.stripe.com → Developers → API keys
STRIPE_SECRET_KEY=sk_test_...
STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
# Create these in Stripe Dashboard → Products
STRIPE_PRO_PRICE_ID=price_...
STRIPE_ENTERPRISE_PRICE_ID=price_...

# ── App URL ───────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
